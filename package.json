{
  "name": "pinny",
  "private": true,
  "version": "1.0.5",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "cross-env NODE_ENV=development concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electronmon .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "electron-updater": "^6.8.9",
    "lowdb": "^7.0.1",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electronmon": "^2.0.4",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "vite": "^8.1.1",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.pinny.app",
    "productName": "Pinny",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["nsis"],
      "icon": "src/assets/icon.png",
      "artifactName": "${productName}-Setup.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "NiklausJoelBJunior",
      "repo": "Pinny-notes-app"
    }
  }
}